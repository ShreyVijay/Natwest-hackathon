# No secrets required; the engine reads CSV files from local data/ and uploads/.
PORT=8000
HOST=0.0.0.0
# Comma-separated frontend origins allowed to call this service.
# Example:
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:3000
